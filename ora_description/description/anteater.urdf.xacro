<?xml version="1.0"?>
<robot xmlns:xacro="https://www.ros.org/wiki/xacro" name="erdferkel">
  <xacro:arg name="sim_mode" default="false"/>

  <!-- Include all of the pieces of the robot -->
  <xacro:include filename="anteater_core.xacro"/>
  <xacro:include filename="caster.xacro"/>
  <xacro:include filename="wheel.xacro"/>
  <xacro:include filename="sensors.xacro"/>
  <xacro:include filename="ros2_control.xacro"/>
  <xacro:include filename="camera.xacro"/>
</robot>